-    jdk: Option<&std::path::Path>,
-    sdk: Option<&std::path::Path>,
-) -> String {
-    let mut prefix = String::new();
-    if let Some(jdk) = jdk {
-        prefix.push_str(&format!(
-            "export JAVA_HOME=\"${{JAVA_HOME:-{}}}\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; ",
-            jdk.display()
-        ));
-    }
-    if let Some(sdk) = sdk {
-        prefix.push_str(&format!(
-            "export ANDROID_HOME=\"${{ANDROID_HOME:-{}}}\"; ",
-            sdk.display()
-        ));
-    }
-    prefix
-}
