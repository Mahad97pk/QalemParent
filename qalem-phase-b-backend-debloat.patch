-                all_lines[(line_end as usize)..context_end]
-                    .iter()
-                    .filter(|l| !l.starts_with(">>>>>>>"))
-                    .cloned()
-                    .collect::<Vec<_>>()
-                    .join("\n")
-            } else {
-                String::new()
-            };
-
-            conflicts.push(ConflictBlock {
-                line_start,
-                line_end,
-                current_content: current_content.join("\n"),
-                incoming_content: incoming_content.join("\n"),
-                context_before,
-                context_after,
