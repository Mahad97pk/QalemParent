-/// Find the agent binary path.
-fn find_agent_binary(agent: &crate::agent::AgentConfig) -> Result<std::path::PathBuf, String> {
-    find_executable(agent.binary_name)
-        .ok_or_else(|| format!("{} binary not found", agent.display_name))
-}
