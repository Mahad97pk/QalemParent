-/// Represents an MCP server configured for an agent.
-#[derive(Debug, Serialize, Clone)]
-pub struct McpServer {
-    /// Server name (identifier)
-    pub name: String,
-    /// The command string (for stdio) or URL (for http/sse)
-    pub command_or_url: String,
